# TeraiD Pay API のベース URL
NEXT_PUBLIC_TERAID_PAY_API_BASE_URL=http://localhost:8005

# WalletConnect の Project ID
# https://cloud.walletconnect.com/ で取得した値を設定してください。
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=d5c0379c278edaf15fba65a3d4cedd31

# Ethereum Mainnet の RPC URL
NEXT_PUBLIC_RPC_URL_ETHEREUM_MAINNET=https://ethereum-rpc.publicnode.com

# Ethereum Sepolia の RPC URL
NEXT_PUBLIC_RPC_URL_ETHEREUM_SEPOLIA=https://ethereum-sepolia-rpc.publicnode.com

# Polygon Mainnet の RPC URL
NEXT_PUBLIC_RPC_URL_POLYGON_MAINNET=https://polygon-bor-rpc.publicnode.com

# Polygon Amoy の RPC URL
NEXT_PUBLIC_RPC_URL_POLYGON_AMOY=https://polygon-amoy-bor-rpc.publicnode.com

# JPYC トークンコントラクトアドレス
NEXT_PUBLIC_JPYC_TOKEN_ADDRESS_ETHEREUM_MAINNET=0x431D5dfF03120AFA4bDf332c61A6e1766eF37BDB
NEXT_PUBLIC_JPYC_TOKEN_ADDRESS_ETHEREUM_SEPOLIA=0xE7C3D8C9a439feDe00D2600032D5dB0Be71C3c29
NEXT_PUBLIC_JPYC_TOKEN_ADDRESS_POLYGON_MAINNET=0x431D5dfF03120AFA4bDf332c61A6e1766eF37BDB
NEXT_PUBLIC_JPYC_TOKEN_ADDRESS_POLYGON_AMOY=0x0000000000000000000000000000000000000000
