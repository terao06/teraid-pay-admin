# TeraiD Pay API のベース URL
NEXT_PUBLIC_TERAID_PAY_API_BASE_URL=http://localhost:8005

# WalletConnect の Project ID
# https://cloud.walletconnect.com/ で取得した値を設定してください。
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=your_wallet_connect_project_id

# Ethereum Mainnet の RPC URL
NEXT_PUBLIC_RPC_URL_ETHEREUM_MAINNET=https://your-ethereum-mainnet-rpc.example

# Ethereum Sepolia の RPC URL
NEXT_PUBLIC_RPC_URL_ETHEREUM_SEPOLIA=https://your-ethereum-sepolia-rpc.example

# Polygon Mainnet の RPC URL
NEXT_PUBLIC_RPC_URL_POLYGON_MAINNET=https://your-polygon-mainnet-rpc.example

# Polygon Amoy の RPC URL
NEXT_PUBLIC_RPC_URL_POLYGON_AMOY=https://your-polygon-amoy-rpc.example

# JPYC トークンコントラクトアドレス
NEXT_PUBLIC_JPYC_TOKEN_ADDRESS_ETHEREUM_MAINNET=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_JPYC_TOKEN_ADDRESS_ETHEREUM_SEPOLIA=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_JPYC_TOKEN_ADDRESS_POLYGON_MAINNET=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_JPYC_TOKEN_ADDRESS_POLYGON_AMOY=0x0000000000000000000000000000000000000000
